# Copy this file to `.env.release` and fill in your Apple notarization creds.
# `.env.release` is gitignored — never commit real credentials (this repo is public).
#
#   cp .env.release.example .env.release
#   # then edit .env.release with your values
#
# APPLE_ID                    -> your Apple Developer account email
# APPLE_APP_SPECIFIC_PASSWORD -> appleid.apple.com -> Sign-In & Security -> App-Specific Passwords
# APPLE_TEAM_ID               -> developer.apple.com -> Membership (10 chars)

APPLE_ID="you@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="XXXXXXXXXX"
